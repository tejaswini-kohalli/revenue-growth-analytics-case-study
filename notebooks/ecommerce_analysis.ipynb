# =========================
# 1. IMPORT LIBRARIES
# =========================
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import sqlite3

# =========================
# 2. LOAD DATA
# =========================
df = pd.read_csv("ecommerce.csv.csv", nrows=200000)

# =========================
# 3. DATA CLEANING
# =========================
df['event_time'] = pd.to_datetime(df['event_time'], errors='coerce')

df['date'] = df['event_time'].dt.date
df['month'] = df['event_time'].dt.to_period('M')

df.dropna(subset=['user_id', 'event_type'], inplace=True)

# =========================
# 4. FUNNEL ANALYSIS
# =========================
viewers = df[df['event_type'] == 'view']['user_id'].nunique()
cart_users = df[df['event_type'] == 'cart']['user_id'].nunique()
buyers = df[df['event_type'] == 'purchase']['user_id'].nunique()

view_to_cart = cart_users / viewers
cart_to_purchase = buyers / cart_users
overall_conversion = buyers / viewers

print("View → Cart:", view_to_cart)
print("Cart → Purchase:", cart_to_purchase)
print("Overall Conversion:", overall_conversion)

# =========================
# 5. FUNNEL SIMULATION 
# =========================
# Business hypothesis: improve cart → purchase conversion

improved_cart_to_purchase = 0.09  # assumed improvement

projected_buyers = cart_users * improved_cart_to_purchase
additional_buyers = projected_buyers - buyers

print("Projected Buyers:", projected_buyers)
print("Additional Buyers:", additional_buyers)

# =========================
# 6. REVENUE ANALYSIS
# =========================
purchases = df[df['event_type'] == 'purchase']

total_revenue = purchases['price'].sum()
aov = purchases['price'].mean()

print("Total Revenue:", total_revenue)
print("AOV:", aov)

# Monthly revenue trend
monthly_revenue = purchases.groupby('month')['price'].sum()

monthly_revenue.plot(title="Monthly Revenue Trend")
plt.xlabel("Month")
plt.ylabel("Revenue")
plt.show()

# =========================
# 7. REPEAT PURCHASE ANALYSIS
# =========================
purchase_counts = purchases.groupby('user_id').size()

repeat_users = purchase_counts[purchase_counts > 1].count()
total_buyers = purchase_counts.count()

repeat_rate = repeat_users / total_buyers

print("Repeat Users:", repeat_users)
print("Total Buyers:", total_buyers)
print("Repeat Rate:", repeat_rate)

# =========================
# 8. LTV & CAC ANALYSIS
# =========================
avg_purchase_frequency = purchase_counts.mean()

ltv = aov * avg_purchase_frequency

# CAC scenarios
cac_1 = 3
cac_2 = 5

ltv_cac_ratio_1 = ltv / cac_1
ltv_cac_ratio_2 = ltv / cac_2

# Max sustainable CAC (for 3:1 ratio)
max_sustainable_cac = ltv / 3

print("Avg Purchase Frequency:", avg_purchase_frequency)
print("LTV:", ltv)
print("LTV:CAC (CAC=3):", ltv_cac_ratio_1)
print("LTV:CAC (CAC=5):", ltv_cac_ratio_2)
print("Max Sustainable CAC:", max_sustainable_cac)

# =========================
# 9. SQL LAYER (SQLite INTEGRATION)
# =========================
df_sql = df.copy()

conn = sqlite3.connect("ecommerce.db")

df_sql.to_sql("events", conn, if_exists="replace", index=False)

print("Database created successfully")

# Funnel SQL
print(pd.read_sql("""
SELECT event_type, COUNT(DISTINCT user_id) AS users
FROM events
GROUP BY event_type
""", conn))

# Revenue SQL
print(pd.read_sql("""
SELECT 
    SUM(price) AS total_revenue,
    AVG(price) AS aov
FROM events
WHERE event_type='purchase'
""", conn))

# Top brands
print(pd.read_sql("""
SELECT brand, SUM(price) AS revenue
FROM events
WHERE event_type='purchase'
GROUP BY brand
ORDER BY revenue DESC
LIMIT 5
""", conn))

# Repeat users
print(pd.read_sql("""
SELECT user_id, COUNT(*) AS purchases
FROM events
WHERE event_type='purchase'
GROUP BY user_id
HAVING COUNT(*) > 1
""", conn))

# =========================
# 10. BUSINESS SUMMARY OUTPUT
# =========================
print("\n===== BUSINESS INSIGHTS =====")

print("Funnel conversion is low at purchase stage.")
print("Revenue depends heavily on repeat users.")
print("LTV:CAC ratio is strong, indicating scalability.")
print("Biggest opportunity: improve cart → purchase conversion.")
